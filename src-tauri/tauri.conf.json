{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Blip",
  "version": "0.1.0",
  "identifier": "com.infamousvague.blip",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bash src-tauri/scripts/build-ne.sh; bash src-tauri/scripts/dev-app-wrapper.sh; npm run dev",
    "beforeBuildCommand": "npm run build && bash src-tauri/scripts/build-ne.sh"
  },
  "app": {
    "windows": [
      {
        "title": "Blip",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "entitlements": "Entitlements.plist",
      "signingIdentity": "0DC37DDD2017A98417402DE8D82578990E26E2D5"
    },
    "resources": [
      "resources/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
