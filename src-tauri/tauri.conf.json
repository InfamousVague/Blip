{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Blip",
  "version": "0.4.1",
  "identifier": "com.infamousvague.blip",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bash src-tauri/scripts/build-ne.sh; bash src-tauri/scripts/dev-app-wrapper.sh; npm run dev",
    "beforeBuildCommand": "npm run build && bash src-tauri/scripts/build-ne.sh"
  },
  "app": {
    "windows": [
      {
        "title": "Blip",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 20,
          "y": 25
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "entitlements": "Entitlements.plist",
      "signingIdentity": "0948896DC970503ADEF5B5070E0BB3E9D9047757"
    },
    "resources": [
      "resources/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/InfamousVague/Blip/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE0NTY3RTY0OTlCNDZFMUMKUldRY2JyU1paSDVXcEhnOWs3UVpQODY0SU9adzdOVm9mNDlmOGxSM2hRdDNsSjhibHNxeFNVcisK"
    }
  }
}
